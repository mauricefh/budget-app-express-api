{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": "./src",
    "paths": {
      "@/types/*": [
        "./types/*"
      ],
      "@/services/*": [
        "./services/*"
      ],
      "@/routes/*": [
        "./routes/*"
      ],
      "@/middleware/*": [
        "./middleware/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ]
    }
  }
}